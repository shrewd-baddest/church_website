<%- include('partials/header') %>

    <section class="hub-hero" data-reveal="fade-up">
        <div class="hero-content">
            <span class="hero-badge">Catholic Student Association</span>
            <h2>Our Sacred Ministries</h2>
            <p>Welcome to our vibrant spiritual home. Explore our diverse ministries, join us in faith, and serve with
                passion as we grow together in Christ.</p>
        </div>
    </section>

    <div class="module-grid">
        <% modules.forEach((mod, index)=> { %>
            <a href="<%= mod.path %>" class="module-card hover-lift hover-glow" data-reveal="fade-up"
                data-delay="<%= index * 100 %>"
                style="--card-icon-color: <%= mod.color %>; --card-icon-color-dark: <%= mod.color %>dd;">
                <div class="module-card__icon">
                    <i class="<%= mod.icon %>"></i>
                    <span class="dot"></span>
                </div>
                <div class="module-card__content">
                    <span class="category-tag">Ministry</span>
                    <h3>
                        <%= mod.title %>
                    </h3>
                    <p>
                        <%= mod.description %>
                    </p>
                </div>
                <div class="module-card__footer">
                    <span class="btn-premium">Explore Portal <i class="fas fa-chevron-right"></i></span>
                </div>
            </a>
            <% }) %>
    </div>

    <%- include('partials/footer') %>