<%- include('partials/header') %>

    <header class="module-header" style="--theme-primary: #1e3a8a; --theme-primary-dark: #172554;">
        <a href="/community-hub" class="back-link"><i class="fas fa-arrow-left"></i> Hub</a>

        <div data-reveal="fade-up">
            <div class="module-logo-bg">
                <i class="fas fa-music" style="font-size: 2rem; color: white;"></i>
            </div>
            <h1>Choir Ministry</h1>
            <p class="description">Join our heavenly voices in praise and worship as we lift our spirits to the Lord.
            </p>
        </div>
    </header>

    <div class="module-page container">
        <div class="choir-container" data-reveal="fade-up">
            <iframe src="/community-assets/pages/index.html" frameborder="0" class="choir-iframe" id="choir-frame"></iframe>
        </div>
    </div>

    <style>
        .full-height {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .choir-container {
            flex: 1;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            margin-bottom: 2rem;
            min-height: 80vh;
        }

        .choir-iframe {
            width: 100%;
            height: 100%;
            min-height: 80vh;
            border: none;
        }

        .container {
            max-width: 1200px;
            /* Slightly wider for the embedded choir */
        }
    </style>

    <%- include('partials/footer') %>